{
  "name": "vituralhwang",
  "version": "1.0.0",
  "private": true,
  "scripts": {
    "predev": "node updateConfig.js",
    "dev": "concurrently \"npm:next:dev\" \"npm:slicemachine\" \"npm:mcp\" --names \"next,slicemachine,mcp\" --prefix-colors blue,magenta,cyan",
    "next:dev": "next dev -H 0.0.0.0",
    "mcp": "npx -y @prismicio/mcp-server@latest",
    "prebuild": "node updateConfig.js",
    "build": "rm -rf .next/cache/fetch-cache && next build",
    "start": "next start",
    "lint": "eslint",
    "slicemachine": "start-slicemachine",
    "format": "prettier --write .",
    "clear": "rm -rf .slicemachine/cache && rm -rf .slicemachine/instance && rm -rf .slicemachine/instance.lock && rm -rf node_modules && rm -rf .next"
  },
  "dependencies": {
    "@gsap/react": "^2.1.2",
    "@prismicio/client": "^7.20.1",
    "@prismicio/next": "^2.0.1",
    "@prismicio/react": "^3.2.1",
    "@vercel/analytics": "^1.5.0",
    "clsx": "^2.1.1",
    "gsap": "^3.13.0",
    "lenis": "^1.3.11",
    "lodash": "^4.17.21",
    "next": "15.5.4",
    "react": "19.1.0",
    "react-dom": "19.1.0",
    "react-haiku": "^2.4.1",
    "sass": "^1.93.2",
    "tempus": "^1.0.0-dev.12",
    "zustand": "^5.0.8"
  },
  "devDependencies": {
    "@eslint/eslintrc": "^3",
    "@slicemachine/adapter-next": "^0.3.84",
    "@types/lodash": "^4.17.20",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "concurrently": "^9.2.1",
    "eslint": "^9",
    "eslint-config-next": "15.5.4",
    "slice-machine-ui": "^2.18.2",
    "typescript": "^5"
  }
}
