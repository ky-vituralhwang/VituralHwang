      "uid": {
        "type": "UID",
        "config": {
          "label": "UID"
        }
      },
      "title": {
        "type": "Text",
        "config": {
          "label": "Title",
          "placeholder": ""
        }
      },
      "detail_title": {
        "type": "Text",
        "config": {
          "label": "Detail Title",
          "placeholder": ""
        }
      },
      "detail_scope": {
        "type": "Text",
        "config": {
          "label": "Detail Scope",
          "placeholder": ""
        }
      },
      "year": {
        "type": "Number",
        "config": {
          "label": "Year of Project Implementation",
          "placeholder": ""
        }
      },
      "thumbnail": {
        "type": "Image",
        "config": {
          "label": "Thumbnail",
          "constraint": {},
          "thumbnails": []
        }
      },
      "feature_media": {
        "type": "Link",
        "config": {
          "label": "Feature Media(Video)",
          "placeholder": "",
          "select": "media",
          "allowText": false
